# Neon PostgreSQL bağlantı URL'si
# neon.tech üzerinden alınır → Project Settings → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Hata bildirimi için e-posta (opsiyonel)
ALERT_EMAIL_FROM=scraper@example.com
ALERT_EMAIL_TO=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your-app-password
