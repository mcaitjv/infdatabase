# Neon PostgreSQL bağlantı URL'si
# neon.tech üzerinden alınır → Project Settings → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# E-posta bildirimi — Resend API (resend.com, ücretsiz)
# RESEND_API_KEY: dashboard → API Keys → Create (Sending access)
# ALERT_EMAIL_TO: raporun gideceği adres (senin emailin)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL_TO=you@example.com

# Notion entegrasyonu (opsiyonel — docs/notion_sync.py için)
NOTION_TOKEN=ntn_xxx...
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
